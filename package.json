{
  "name": "ors",
  "displayName": "Örs",
  "description": "Örs — kendi local LLM'lerinle çalışan, dosya okuyup düzenleyebilen ve komut çalıştırabilen agentic kodlama asistanı. Kodun dövüldüğü yer.",
  "version": "0.1.0",
  "publisher": "local",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/habibkaratas/ors"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ors",
          "title": "Örs",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ors": [
        {
          "type": "webview",
          "id": "ors.chat",
          "name": "Sohbet"
        }
      ]
    },
    "commands": [
      {
        "command": "ors.newChat",
        "title": "Örs: Yeni Sohbet",
        "icon": "$(add)"
      },
      {
        "command": "ors.undo",
        "title": "Örs: Son Değişiklikleri Geri Al",
        "icon": "$(discard)"
      },
      {
        "command": "ors.setHost",
        "title": "Örs: Ollama Host Seç/Ekle",
        "icon": "$(server)"
      },
      {
        "command": "ors.manageHosts",
        "title": "Örs: Host Yönetimi",
        "icon": "$(server)"
      },
      {
        "command": "ors.focus",
        "title": "Örs: Paneli Aç"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ors.setHost",
          "when": "view == ors.chat",
          "group": "navigation@1"
        },
        {
          "command": "ors.undo",
          "when": "view == ors.chat",
          "group": "navigation@2"
        },
        {
          "command": "ors.newChat",
          "when": "view == ors.chat",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Örs",
      "properties": {
        "ors.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Aktif Ollama sunucu adresi. Panelden host seçici ile de değiştirilebilir."
        },
        "ors.hosts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "http://localhost:11434"
          ],
          "description": "Kayıtlı Ollama host'ları (yerel + uzak). Panelden yeni host eklenir."
        },
        "ors.workspaceOnly": {
          "type": "boolean",
          "default": false,
          "description": "Açık: ajan yalnızca açık proje/kök dizininde çalışır. Kapalı (varsayılan): genel makine ajanı — tüm diske erişebilir."
        },
        "ors.model": {
          "type": "string",
          "default": "",
          "description": "Kullanılacak model adı (örn. qwen2.5-coder:7b). Boşsa panelden seçebilirsin."
        },
        "ors.temperature": {
          "type": "number",
          "default": 0.2,
          "description": "Örnekleme sıcaklığı. Kodlama için düşük değerler (0.1-0.3) önerilir."
        },
        "ors.maxIterations": {
          "type": "number",
          "default": 25,
          "description": "Ajanın tek bir istek için yapabileceği maksimum tool-call döngü sayısı."
        },
        "ors.autoApprove": {
          "type": "object",
          "default": {
            "read": true,
            "search": true,
            "list": true,
            "write": false,
            "command": false
          },
          "description": "Hangi araçların onay istemeden çalışacağı. write ve command'i güvendiğinde açabilirsin."
        },
        "ors.contextWindow": {
          "type": "number",
          "default": 65536,
          "description": "Modele gönderilecek num_ctx (bağlam penceresi) değeri. Büyük değer bağlamın daha geç kopmasını sağlar ama daha çok RAM/VRAM ister. qwen3.6 gibi büyük modeller 65536+ destekler; bellek kısıtı varsa 32768'e düşürün."
        },
        "ors.commandAllowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "git status",
            "git diff",
            "git log",
            "ls",
            "dir",
            "cat",
            "type",
            "echo",
            "pwd",
            "node -v",
            "npm test",
            "npm run",
            "npx tsc"
          ],
          "description": "Bu öneklerle başlayan komutlar onay istemeden çalışır."
        },
        "ors.commandDenylist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "rm ",
            "del ",
            "rmdir",
            "git push",
            "format",
            "shutdown",
            "reg delete",
            "sudo"
          ],
          "description": "Bu öneklerle başlayan komutlar allowlist'te olsa bile her zaman onay ister."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies -o ors.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
